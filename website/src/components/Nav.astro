---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---
<nav id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={`${base}`} class="flex items-center gap-3 group">
      <img src={`${base}seaclaw.svg`} alt="SeaClaw logo" class="w-7 h-7 transition-transform duration-300 group-hover:scale-110" />
      <span class="text-[15px] font-semibold tracking-tight" style="color: var(--color-text)">SeaClaw</span>
    </a>
    <div class="flex items-center gap-8">
      <div class="hidden md:flex items-center gap-6">
        <a href="#use-cases" class="text-[13px] transition-colors" style="color: var(--color-text-secondary)" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-secondary)'" onfocus="this.style.color='var(--color-text)'" onblur="this.style.color='var(--color-text-secondary)'">Use Cases</a>
        <a href="#architecture" class="text-[13px] transition-colors" style="color: var(--color-text-secondary)" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-secondary)'" onfocus="this.style.color='var(--color-text)'" onblur="this.style.color='var(--color-text-secondary)'">Architecture</a>
        <a href={`${base}getting-started/installation/`} class="text-[13px] transition-colors" style="color: var(--color-text-secondary)" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-secondary)'" onfocus="this.style.color='var(--color-text)'" onblur="this.style.color='var(--color-text-secondary)'">Docs</a>
      </div>
      <a href="https://github.com/sethdford/seaclaw" target="_blank" rel="noopener noreferrer" class="transition-colors" style="color: var(--color-text-secondary)" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-secondary)'" aria-label="GitHub">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
      </a>
      <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center w-8 h-8" style="color: var(--color-text-secondary)" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="hamburger-icon w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
        <svg class="close-icon w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="md:hidden hidden" style="background: var(--color-surface-elevated); backdrop-filter: blur(24px) saturate(1.8); -webkit-backdrop-filter: blur(24px) saturate(1.8); border-bottom: 1px solid var(--color-border);">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-3">
      <a href="#use-cases" class="mobile-menu-link text-[15px] py-2 transition-colors" style="color: var(--color-text-secondary)">Use Cases</a>
      <a href="#architecture" class="mobile-menu-link text-[15px] py-2 transition-colors" style="color: var(--color-text-secondary)">Architecture</a>
      <a href={`${base}getting-started/installation/`} class="mobile-menu-link text-[15px] py-2 transition-colors" style="color: var(--color-text-secondary)">Docs</a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const hamburger = btn?.querySelector(".hamburger-icon");
  const closeIcon = btn?.querySelector(".close-icon");

  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(open));
    hamburger?.classList.toggle("hidden", open);
    closeIcon?.classList.toggle("hidden", !open);
  });

  menu?.querySelectorAll(".mobile-menu-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
      hamburger?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
    });
  });
</script>
