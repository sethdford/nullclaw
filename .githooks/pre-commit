#!/bin/sh
# pre-commit: auto-format C files, format check, design token lint.
# Activate: git config core.hooksPath .githooks

CLANG_FMT="clang-format"
if ! command -v "$CLANG_FMT" >/dev/null 2>&1; then
    for p in /opt/homebrew/opt/llvm/bin/clang-format /usr/local/opt/llvm/bin/clang-format; do
        if [ -x "$p" ]; then CLANG_FMT="$p"; break; fi
    done
fi

if [ -d "src" ] && [ -f "CMakeLists.txt" ]; then
    staged_ch=$(git diff --cached --name-only --diff-filter=ACM -- '*.c' '*.h')
    if [ -n "$staged_ch" ]; then
        for f in $staged_ch; do
            if grep -qn '	' "$f" 2>/dev/null; then
                echo "Warning: tabs found in $f (project uses spaces)"
            fi
        done
        # Auto-format staged files, then re-stage them
        echo "$staged_ch" | xargs "$CLANG_FMT" -i 2>/dev/null
        echo "$staged_ch" | xargs git add
        # Verify formatting is clean
        echo "$staged_ch" | xargs "$CLANG_FMT" --dry-run -Werror
        if [ $? -ne 0 ]; then
            echo "clang-format failed even after auto-format. Check .clang-format config."
            exit 1
        fi
    fi
fi

# Check for declared-but-undefined symbols in staged headers
if [ -d "build" ] && [ -f "build/libseaclaw_core.a" ]; then
    staged_h=$(git diff --cached --name-only --diff-filter=ACM -- 'include/seaclaw/*.h' 'include/seaclaw/**/*.h')
    if [ -n "$staged_h" ]; then
        UNDEFS=$(nm -u build/libseaclaw_core.a 2>/dev/null | grep ' U _sc_' | sort -u || true)
        if [ -n "$UNDEFS" ]; then
            echo "Warning: possibly undefined sc_* symbols in library:"
            echo "$UNDEFS" | head -10
        fi
    fi
fi

# Lint for raw hex colors in staged CSS/TS/Astro files
# Skip token definition files (they define the colors themselves)
if [ -x "scripts/lint-raw-colors.sh" ]; then
    staged_style=$(git diff --cached --name-only --diff-filter=ACM -- '*.css' '*.ts' '*.tsx' '*.astro' | grep -v 'tokens\.' | grep -v 'design-tokens/')
    if [ -n "$staged_style" ]; then
        ./scripts/lint-raw-colors.sh
        if [ $? -ne 0 ]; then
            echo "Raw hex color lint failed. Use --sc-* or --sc-web-* design tokens instead."
            exit 1
        fi
    fi
fi
