{
  "$description": "Motion tokens — duration, easing, spring, choreography, and purpose-based transitions",
  "duration": {
    "instant": {
      "$value": "50ms",
      "$type": "duration",
      "$description": "Imperceptible delay"
    },
    "fast": {
      "$value": "100ms",
      "$type": "duration",
      "$description": "Micro-interactions"
    },
    "normal": {
      "$value": "200ms",
      "$type": "duration",
      "$description": "Standard transitions"
    },
    "moderate": {
      "$value": "300ms",
      "$type": "duration",
      "$description": "Moderate transitions"
    },
    "slow": {
      "$value": "350ms",
      "$type": "duration",
      "$description": "Complex transitions"
    },
    "slower": {
      "$value": "500ms",
      "$type": "duration",
      "$description": "Dramatic reveals"
    },
    "slowest": {
      "$value": "700ms",
      "$type": "duration",
      "$description": "Hero/page transitions"
    }
  },
  "easing": {
    "linear": { "$value": "linear", "$type": "cubicBezier" },
    "ease-out": {
      "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
      "$type": "cubicBezier"
    },
    "ease-in-out": {
      "$value": "cubic-bezier(0.65, 0, 0.35, 1)",
      "$type": "cubicBezier"
    },
    "ease-in": {
      "$value": "cubic-bezier(0.55, 0, 1, 0.45)",
      "$type": "cubicBezier"
    },
    "spring-out": {
      "$value": "linear(0, 0.006, 0.025 2.8%, 0.101 6.1%, 0.539 18.9%, 0.721 25.3%, 0.849 31.5%, 0.937 38.1%, 0.968 41.8%, 0.991 45.7%, 1.006 50.1%, 1.015 55%, 1.017 63.9%, 1.001 85.9%, 1)",
      "$type": "cubicBezier",
      "$description": "CSS linear() approximation of spring(stiffness:200, damping:20)"
    },
    "spring-bounce": {
      "$value": "linear(0, 0.004, 0.016, 0.035 4%, 0.147 8%, 0.51 17.2%, 0.726 23.1%, 0.884 28.9%, 0.976 34%, 1.019 38.3%, 1.045 42.5%, 1.054 47.7%, 1.04 56.7%, 1.017 64.3%, 1.003 76%, 1)",
      "$type": "cubicBezier",
      "$description": "CSS linear() with slight bounce overshoot"
    },
    "emphasize": {
      "$value": "cubic-bezier(0.2, 0, 0, 1)",
      "$type": "cubicBezier",
      "$description": "Dramatic deceleration for emphasis animations"
    }
  },
  "spring": {
    "$description": "Physics-based spring parameters for native platforms and JS animation libs",
    "micro": {
      "stiffness": { "$value": 400, "$type": "number" },
      "damping": { "$value": 30, "$type": "number" },
      "mass": { "$value": 1, "$type": "number" },
      "$description": "Button press, toggle (~100ms settle)"
    },
    "standard": {
      "stiffness": { "$value": 200, "$type": "number" },
      "damping": { "$value": 20, "$type": "number" },
      "mass": { "$value": 1, "$type": "number" },
      "$description": "Panel slide, dropdown open (~250ms settle)"
    },
    "expressive": {
      "stiffness": { "$value": 120, "$type": "number" },
      "damping": { "$value": 14, "$type": "number" },
      "mass": { "$value": 1, "$type": "number" },
      "$description": "Page transition, modal enter (~400ms settle)"
    },
    "dramatic": {
      "stiffness": { "$value": 80, "$type": "number" },
      "damping": { "$value": 10, "$type": "number" },
      "mass": { "$value": 1, "$type": "number" },
      "$description": "Hero reveal, onboarding (~600ms settle)"
    }
  },
  "purpose": {
    "$description": "Purpose-based motion presets for specific interaction types",
    "enter": {
      "duration": { "$value": "{duration.normal}", "$type": "duration" },
      "easing": { "$value": "{easing.ease-out}", "$type": "cubicBezier" },
      "$description": "Element enters viewport or DOM"
    },
    "exit": {
      "duration": { "$value": "{duration.fast}", "$type": "duration" },
      "easing": { "$value": "{easing.ease-in}", "$type": "cubicBezier" },
      "$description": "Element leaves viewport or DOM"
    },
    "emphasize": {
      "duration": { "$value": "{duration.slow}", "$type": "duration" },
      "easing": { "$value": "{easing.emphasize}", "$type": "cubicBezier" },
      "$description": "Attention-drawing animation"
    },
    "move": {
      "duration": { "$value": "{duration.normal}", "$type": "duration" },
      "easing": { "$value": "{easing.ease-in-out}", "$type": "cubicBezier" },
      "$description": "Element repositioning (layout shift, reorder)"
    },
    "page-enter": {
      "duration": { "$value": "{duration.slow}", "$type": "duration" },
      "easing": { "$value": "{easing.ease-out}", "$type": "cubicBezier" },
      "$description": "Page/view entering"
    },
    "page-exit": {
      "duration": { "$value": "{duration.fast}", "$type": "duration" },
      "easing": { "$value": "{easing.ease-in}", "$type": "cubicBezier" },
      "$description": "Page/view exiting"
    },
    "shared-element": {
      "duration": { "$value": "{duration.slow}", "$type": "duration" },
      "easing": { "$value": "{easing.spring-out}", "$type": "cubicBezier" },
      "$description": "Shared element transition between views"
    }
  },
  "choreography": {
    "$description": "Stagger and cascade timing",
    "stagger-delay": { "$value": "50ms", "$type": "duration" },
    "stagger-max": { "$value": "300ms", "$type": "duration" },
    "cascade-delay": { "$value": "30ms", "$type": "duration" },
    "cascade-max": { "$value": "200ms", "$type": "duration" }
  },
  "reduced-motion": {
    "$description": "Alternative values when prefers-reduced-motion: reduce is active",
    "duration-override": { "$value": "0ms", "$type": "duration" },
    "spring-override-damping": {
      "$value": 100,
      "$type": "number",
      "$description": "Overdamped — no bounce"
    }
  },
  "transition": {
    "default": {
      "$value": "150ms cubic-bezier(0.16, 1, 0.3, 1)",
      "$type": "transition",
      "$description": "Standard transition using ease-out curve"
    }
  },
  "micro-physics": {
    "$description": "Pixar-inspired micro-physics presets — anticipation, follow-through, squash/stretch for UI elements",
    "button-press": {
      "scaleX": { "$value": 1.01, "$type": "number" },
      "scaleY": { "$value": 0.97, "$type": "number" },
      "$description": "Squash on press — slight horizontal expand, vertical compress"
    },
    "button-release": {
      "scaleX": { "$value": 0.99, "$type": "number" },
      "scaleY": { "$value": 1.02, "$type": "number" },
      "$description": "Stretch on release — vertical overshoot before settling"
    },
    "modal-anticipate": {
      "scale": { "$value": 0.97, "$type": "number" },
      "pause": { "$value": "50ms", "$type": "duration" },
      "$description": "Modal shrinks slightly before expanding (anticipation)"
    },
    "card-hover": {
      "translateY": { "$value": "-2px", "$type": "string" },
      "$description": "Subtle lift on hover — perceived lightness"
    },
    "dropdown-anticipate": {
      "scaleY": { "$value": 0.98, "$type": "number" },
      "$description": "Dropdown compresses from origin before expanding"
    },
    "toggle-squash": {
      "scaleX": { "$value": 1.15, "$type": "number" },
      "scaleY": { "$value": 0.85, "$type": "number" },
      "$description": "Toggle thumb squashes during slide"
    }
  }
}
