{
  "$description": "Typography tokens — font families, sizes, weights, line-heights, letter-spacing",
  "fontFamily": {
    "sans": {
      "$value": "'Avenir', 'Avenir Next', -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
      "$type": "fontFamily"
    },
    "mono": {
      "$value": "'Geist Mono', ui-monospace, 'SF Mono', monospace",
      "$type": "fontFamily"
    }
  },
  "fontSize": {
    "xs": {
      "$value": "0.6875rem",
      "$type": "dimension",
      "$description": "11px"
    },
    "sm": {
      "$value": "0.8125rem",
      "$type": "dimension",
      "$description": "13px"
    },
    "base": {
      "$value": "0.875rem",
      "$type": "dimension",
      "$description": "14px"
    },
    "lg": { "$value": "1rem", "$type": "dimension", "$description": "16px" },
    "xl": { "$value": "1.25rem", "$type": "dimension", "$description": "20px" },
    "2xl": {
      "$value": "clamp(1.25rem, 3vw, 1.75rem)",
      "$type": "dimension",
      "$description": "Fluid 20–28px"
    },
    "hero": {
      "$value": "clamp(2rem, 5vw, 3.5rem)",
      "$type": "dimension",
      "$description": "Fluid 32–56px"
    }
  },
  "fontWeight": {
    "light": {
      "$value": 300,
      "$type": "number",
      "$description": "Avenir Light"
    },
    "normal": {
      "$value": 400,
      "$type": "number",
      "$description": "Avenir Book"
    },
    "medium": {
      "$value": 500,
      "$type": "number",
      "$description": "Avenir Medium"
    },
    "semibold": {
      "$value": 600,
      "$type": "number",
      "$description": "Avenir Medium (no 600 weight; aliased to 500)"
    },
    "bold": {
      "$value": 700,
      "$type": "number",
      "$description": "Avenir Heavy"
    },
    "black": {
      "$value": 900,
      "$type": "number",
      "$description": "Avenir Black"
    }
  },
  "lineHeight": {
    "tight": { "$value": 1.25, "$type": "number" },
    "normal": { "$value": 1.5, "$type": "number" },
    "relaxed": { "$value": 1.75, "$type": "number" }
  },
  "letterSpacing": {
    "$description": "Optical size compensation — tighter tracking at larger sizes",
    "xs": { "$value": "0.02em", "$type": "dimension" },
    "sm": { "$value": "0.01em", "$type": "dimension" },
    "base": { "$value": "0em", "$type": "dimension" },
    "lg": { "$value": "0em", "$type": "dimension" },
    "xl": { "$value": "-0.01em", "$type": "dimension" },
    "2xl": { "$value": "-0.01em", "$type": "dimension" },
    "hero": { "$value": "-0.02em", "$type": "dimension" }
  }
}
